<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Velare</title>
    </head>
    <body>
        <h3>Edit Your Listing</h3>

        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
            <label for="title">Title:</label>
            <input type="text" id="title" name="title" value="<%= listing.title %>" required><br><br>

            <label for="description">Description:</label><br>
            <textarea id="description" name="description" rows="4" cols="50" required><%= listing.description %></textarea><br><br>

            <label for="image">Image URL:</label>
            <input type="text" id="image" name="image" value="<%= listing.image %>"><br><br>

            <label for="price">Price (in INR):</label>
            <input type="number" id="price" name="price" value="<%= listing.price %>" required><br><br>

            <label for="location">Location:</label>
            <input type="text" id="location" name="location" value="<%= listing.location %>" required><br><br>

            <label for="country">Country:</label>
            <input type="text" id="country" name="country" value="<%= listing.country %>" required><br><br>

            <button type="submit">Edit Listing</button>
        </form>
    </body>
</html>