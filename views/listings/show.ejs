<% layout('layouts/boilerplate') %>

<body>
    <div class="row">
        <div class="col-8 offset-3">
            <br /><br />
            <h3><%= listing.title %></h3>
        </div>
        <div class="card col-6 offset-3 show-card">
            <img
                src="<%= listing.image %>"
                class="card-img-top show-img"
                alt="listing_image"
            />
            <div class="card-body">
                <p class="card-text">
                    <%= listing.description %> <br />
                    &#8377;<%= listing.price.toLocaleString("en-IN") %> <br />
                    <%= listing.location %> <br />
                    <%= listing.country %>
                </p>
            </div>
        </div>
    </div>

    <div class="btns">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn"
            >Edit</a
        >

        <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=DELETE"
        >
            <button type="submit" class="btn btn-dark offset-5 delete-btn">
                Delete
            </button>
        </form>
    </div>

    <div class="col-8 offset-3 mb-5">
        <hr>
        <h4>Leave a Review</h4>
        <form class="needs-validation" action="/listings/<%= listing._id %>/reviews" method="POST" novalidate>
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" class="form-range" id="rating" name="review[rating]" min="1" max="5" />
            </div>
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea class="form-control" id="comment" name="review[comment]" cols="30" rows="5" required></textarea>
                <div class="valid-feedback">Comment looks good!</div>
                <div class="invalid-feedback">Please enter a valid comment.</div>
            </div>
            <button type="submit" class="btn btn-primary">Submit Review</button>
        </form>
    </div>
</body>
